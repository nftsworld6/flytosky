// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("USER")
  affiliateCode String?  @unique
  createdAt     DateTime @default(now())

  bookings         Booking[]
  affiliateTracking AffiliateTracking[]

  @@map("users")
}

model Flight {
  id             String   @id @default(cuid())
  airline        String
  flightNumber   String
  departure      String
  arrival        String
  departureTime  DateTime
  arrivalTime    DateTime
  price          Float
  seatsAvailable Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("flights")
}

model Hotel {
  id         String   @id @default(cuid())
  name       String
  location   String
  rating     Float
  pricePerNight Float
  amenities  String
  image      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("hotels")
}

model Car {
  id         String   @id @default(cuid())
  model      String
  type       String
  location   String
  pricePerDay Float
  seats      Int
  image      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("cars")
}

model Restaurant {
  id         String   @id @default(cuid())
  name       String
  location   String
  cuisine    String
  rating     Float
  priceRange String
  image      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("restaurants")
}

model WorkContract {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String
  salary      Float
  type        String
  requirements String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("work_contracts")
}

model Package {
  id         String   @id @default(cuid())
  title      String
  location   String
  hotelName  String
  basePrice  Float
  nights     Int
  inclusions String
  image      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("packages")
}

model Booking {
  id         String        @id @default(cuid())
  userId     String
  type       String
  itemId     String
  totalPrice Float
  status     String        @default("PENDING")
  createdAt  DateTime      @default(now())

  user     User     @relation(fields: [userId], references: [id])
  tracking AffiliateTracking?

  @@map("bookings")
}

model AffiliateTracking {
  id          String  @id @default(cuid())
  affiliateId String
  bookingId   String  @unique
  commission  Float
  createdAt   DateTime @default(now())

  affiliate User    @relation(fields: [affiliateId], references: [id])
  booking   Booking @relation(fields: [bookingId], references: [id])

  @@map("affiliate_tracking")
}